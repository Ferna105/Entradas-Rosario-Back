MERCADOPAGO_ACCESS_TOKEN=your_access_token_here
# Una URL o varias separadas por coma (sin barra final). Debe coincidir con el Origin del navegador.
# También se usa la primera URL para enlaces en emails (p. ej. invitación escaneador).
BASE_URL_FRONT=http://localhost:3000
# Opcional: mismo formato que BASE_URL_FRONT si preferís variable aparte
# CORS_ORIGINS=
BASE_URL_BACK=http://localhost:3001
# OAuth vendedores (Marketplace): Redirect URL idéntica al panel de Mercado Pago.
# Si omitís MP_REDIRECT_URI, se usa BASE_URL_BACK + /mp/callback
# MP_REDIRECT_URI=http://localhost:3001/mp/callback
# MP_APP_ID=
# MP_CLIENT_SECRET=
DB_HOST=example
DB_PORT=example
DB_USER=example
DB_PASS=example
DB_NAME=example